<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="proyecto.deporte.javafx.controller.MainLayoutController" fx:id="mainLayout">
  <left>
    <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #2c3e50; -fx-min-width: 150;">
      <Button text="Dashboard" onAction="#showDashboard" maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
      <Button text="Usuarios" onAction="#showUsers" maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
      <Button text="Reservas" onAction="#showBookings" maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
      <Button text="Estadisticas" onAction="#showStats" maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
    </VBox>
  </left>
  <center>
    <StackPane fx:id="contentArea"/>
  </center>
</BorderPane>